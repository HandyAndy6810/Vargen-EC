{
  "expo": {
    "name": "Vargen",
    "slug": "vgnec",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "vargen",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0E11"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.vargen.ec",
      "backgroundColor": "#f7f4ee",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Used to capture photos for jobs and invoices.",
        "NSPhotoLibraryUsageDescription": "Used to attach photos to jobs and invoices.",
        "NSMicrophoneUsageDescription": "Used for AI voice-to-quote dictation.",
        "NSLocationWhenInUseUsageDescription": "Used to show weather conditions for your location.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Used to show weather conditions for your location.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0D0E11"
      },
      "package": "com.vargen.ec",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.FOREGROUND_SERVICE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "backgroundColor": "#f7f4ee"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1",
            "ccFlags": "-DFOLLY_CFG_NO_COROUTINES=1"
          }
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./node_modules/@expo-google-fonts/manrope/400Regular/Manrope_400Regular.ttf",
            "./node_modules/@expo-google-fonts/manrope/500Medium/Manrope_500Medium.ttf",
            "./node_modules/@expo-google-fonts/manrope/600SemiBold/Manrope_600SemiBold.ttf",
            "./node_modules/@expo-google-fonts/manrope/700Bold/Manrope_700Bold.ttf",
            "./node_modules/@expo-google-fonts/manrope/800ExtraBold/Manrope_800ExtraBold.ttf"
          ]
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#FF5C00",
          "sounds": []
        }
      ],
      "expo-updates",
      "expo-image-picker",
      "expo-location",
      "./plugins/with-folly-fix"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "updates": {
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/481ac436-4f04-451b-8cf6-48aaaf94e24b"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "eas": {
        "projectId": "481ac436-4f04-451b-8cf6-48aaaf94e24b"
      }
    },
    "owner": "handyandy6810"
  }
}
