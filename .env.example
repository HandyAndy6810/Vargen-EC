# ── REQUIRED (app won't start without these) ──────────────────────────────────

# PostgreSQL connection string from Neon (or any Postgres provider)
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=

# Any random string, minimum 32 characters — used to sign session cookies
# Generate one at: https://www.uuidgenerator.net/ (use two UUIDs joined together)
SESSION_SECRET=

# ── SERVER ────────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=5000

# The public URL of this server — used in quote portal links and Xero OAuth redirect
APP_URL=http://localhost:5000

# ── AI (quote generation + voice transcription) ───────────────────────────────

# Your OpenAI API key — get one at platform.openai.com
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# ── EMAIL (Resend) ────────────────────────────────────────────────────────────

# Sign up free at resend.com — 3,000 emails/month free tier
RESEND_API_KEY=
# Must be a domain you've verified in Resend, or use the Resend sandbox address
EMAIL_FROM=noreply@vargen.app

# ── STRIPE (payment links on invoices) ────────────────────────────────────────

# Get from stripe.com → Developers → API keys
STRIPE_SECRET_KEY=
# Get from stripe.com → Webhooks → Add endpoint → your tunnel URL + /api/stripe/webhook
# Leave blank during local dev — webhook verification is skipped if not set
STRIPE_WEBHOOK_SECRET=

# ── TWILIO (SMS follow-ups) ───────────────────────────────────────────────────

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── XERO (accounting sync) ────────────────────────────────────────────────────

# Create a free app at developer.xero.com → My Apps → New App
# Set redirect URI to: http://localhost:5000/api/xero/callback
XERO_CLIENT_ID=
XERO_REDIRECT_URI=http://localhost:5000/api/xero/callback
XERO_SCOPES=openid profile email accounting.transactions accounting.contacts offline_access
XERO_SALES_ACCOUNT_CODE=200
